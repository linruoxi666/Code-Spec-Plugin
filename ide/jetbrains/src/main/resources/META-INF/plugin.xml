<idea-plugin>
    <id>com.codespec.plugin</id>
    <name>Code Spec Plugin</name>
    <version>0.1.0</version>
    <vendor>code-spec</vendor>

    <description><![CDATA[
        Code Spec Plugin for JetBrains IDEs.
    ]]></description>

    <change-notes><![CDATA[
        Initial release.
    ]]></change-notes>

    <idea-version since-build="232"/>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <action id="CodeSpec.EvaluateProject"
                class="com.codespec.plugin.CodeSpecAction"
                text="Evaluate Project"
                description="Run Code Spec evaluation on the current project">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
