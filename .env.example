# LLM 配置
# 支持 OpenAI 及任意 OpenAI 兼容接口（DeepSeek、Kimi、SiliconFlow、智谱、火山、阿里云、百度、腾讯等）

# API Key（必填）
LLM_API_KEY=your-api-key

# 厂商/模型（可选，默认 openai / gpt-4o-mini）
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Base URL（国内厂商必填，OpenAI 可选）
LLM_BASE_URL=https://api.openai.com/v1

# SSL 证书校验（可选，默认 true。若遇到握手/证书错误可设为 false，仅建议开发环境）
LLM_VERIFY_SSL=true
